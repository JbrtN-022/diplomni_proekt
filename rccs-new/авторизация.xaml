<Window x:Class="rccs_new.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Авторизация" 
        Height="620" 
        Width="900"
        WindowStartupLocation="CenterScreen">
    <Window.Background>
        <ImageBrush ImageSource="/загруженное.jpg"/>
    </Window.Background>



    <Grid>
        

        <Border Width="400"
                Height="400"
                Background="White"
                VerticalAlignment="Center"
                HorizontalAlignment="Center"
                CornerRadius="20"
                Padding="40" BorderBrush="#FF797979"
                BorderThickness="2">

            <StackPanel>

                <TextBlock Text="Вход в систему"
                           FontSize="27"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,35"/>

                <!-- ЛОГИН -->
                <TextBox x:Name="txtLogin"
                         materialDesign:HintAssist.Hint="Логин"
                         
                         Height="50"
                         Margin="0,0,0,20"/>

                <!-- ПАРОЛЬ -->
                <PasswordBox x:Name="txtPassword"
                             materialDesign:HintAssist.Hint="Пароль"
                             Style="{StaticResource MaterialDesignPasswordBox  }"
                             Height="50"/>

              
                <CheckBox x:Name="chkShowPassword"
                          Content="Показать пароль"
                          Margin="0,12,0,25"
                          Style="{StaticResource MaterialDesignCheckBox}"
                         Checked="chkShowPassword_Click"/>

             
                <Button x:Name="btnLogin"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        Height="52"
                        Margin="0,10,0,20"
                        Content="Авторизоваться"
                        Click="btnLogin_Click"/>

            </StackPanel>
        </Border>
    </Grid>
</Window>
<Window x:Class="rccs_new.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Авторизация" 
        Height="620" 
        Width="900"
        WindowStartupLocation="CenterScreen">

    <Window.Background>
        <ImageBrush ImageSource="/загруженное.jpg"/>
    </Window.Background>

    <Grid>
        <Border Width="400"
                Height="450"
                Background="White"
                VerticalAlignment="Center"
                HorizontalAlignment="Center"
                CornerRadius="20"
                Padding="30"
                BorderBrush="#FF797979"
                BorderThickness="2">

            <StackPanel>
                <TextBlock Text="Вход в систему"
                           FontSize="27"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,35"/>

                
                <TextBox x:Name="txtLogin"
                         materialDesign:HintAssist.Hint="Логин"
                         Height="35"
                         Margin="0,0,0,20"/>

               
                <Grid x:Name="PasswordContainer" Height="35" Margin="0,0,0,20">
                    <PasswordBox x:Name="txtPassword"
                                 materialDesign:HintAssist.Hint="Пароль"
                                 Style="{StaticResource MaterialDesignPasswordBox}"
                                 Visibility="Visible"/>
                   
                    <TextBox x:Name="txtVisiblePassword"
                             materialDesign:HintAssist.Hint="Пароль"
                            
                             Visibility="Hidden"/>
                </Grid>

               
                <CheckBox x:Name="chkShowPassword"
                          Content="Показать пароль"
                          Margin="0,12,0,25"
                          Style="{StaticResource MaterialDesignCheckBox}"
                          Checked="chkShowPassword_Checked"
                          Unchecked="chkShowPassword_Unchecked"/>

                
                <Button x:Name="btnLogin"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        Height="42"
                        Margin="0,10,0,20"
                        Content="Авторизоваться"
                        Click="btnLogin_Click"/>

                
                <Button x:Name="подключение"
                        Content="Настройки подключения"
                        Height="45"
                        Margin="0,-8"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        Click="подключение_Click"
                        Background="{x:Null}"
                        Foreground="#FF2196F3"/>
            </StackPanel>
        </Border>

        <Border Height="40"
                VerticalAlignment="Bottom"
                Background="#2196F3"
                Panel.ZIndex="-1"/>
    </Grid>
</Window>
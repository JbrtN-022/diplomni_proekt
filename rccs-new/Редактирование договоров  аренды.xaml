<Window x:Class="rccs_new.Редактирование_договоров__аренды"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:rccs_new"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        mc:Ignorable="d"
        Title="Редактирование договоров аренды" Height="720" Width="500">
    <Grid>
        <!-- Верхняя панель с заголовком и кнопкой "Назад" -->
        <Grid Background="#FF2196F3" Height="60" VerticalAlignment="Top">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       Text="Редактирование договоров аренды"
                       Foreground="White"
                       FontSize="22"
                       FontWeight="Medium"
                       VerticalAlignment="Center"
                       Margin="25,0,0,0"/>

            <StackPanel Grid.Column="1"
                       Orientation="Horizontal"
                       HorizontalAlignment="Right"
                       VerticalAlignment="Center"
                       Margin="0,0,20,0">
                <Button x:Name="Back"
                        Style="{StaticResource MaterialDesignToolButton}"
                        Width="45" Height="45"
                        ToolTip="Назад"
                        Margin="5,0" Click="Back_Click">
                    <materialDesign:PackIcon Kind="ArrowBack" Width="26" Height="26" Foreground="White"/>
                </Button>
            </StackPanel>
        </Grid>

        <!-- Основная область с формой -->
        <Border Grid.Row="1" Margin="25,70,15,10" Padding="25" CornerRadius="15" Background="White">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" Opacity="0.12"/>
            </Border.Effect>

            <StackPanel>
                <!-- Номер договора -->
                <TextBlock Text="Номер договора" FontSize="15" Margin="0,0,0,6" FontWeight="Medium"/>
                <TextBox x:Name="txtLicenseNumber"
                          IsReadOnly="True"
                          FontSize="15"
                          Height="48"
                          materialDesign:HintAssist.Hint="Автоматически генерируется"/>

                <!-- Контрагент -->
                <TextBlock Text="Контрагент" FontSize="15" Margin="0,18,0,6" FontWeight="Medium"/>
                <Grid>
                    <ComboBox x:Name="cmbClient"
                      Height="48"
                      FontSize="15"
                      materialDesign:HintAssist.Hint="Выберите контрагента"
                     />
                    <Button Width="45" Height="45" HorizontalAlignment="Right" Margin="0,1,0,0"
                   ToolTip="Добавить нового контрагента">
                        <materialDesign:PackIcon Kind="Plus" Width="26" Height="26" Foreground="White" VerticalAlignment="Center" Margin="-10 0 -10 0"/>
                    </Button>
                </Grid>

                <!-- Этаж -->
                <TextBlock Text="Этаж" FontSize="15" Margin="0,18,0,6" FontWeight="Medium"/>
                <ComboBox x:Name="cmbFloor"
                  Height="48"
                  FontSize="15"
                  materialDesign:HintAssist.Hint="Выберите этаж" SelectionChanged="cmbFloor_SelectionChanged"/>

                <!-- Кабинет / Помещение -->
                <TextBlock Text="Кабинет / Помещение" FontSize="15" Margin="0,18,0,6" FontWeight="Medium"/>
                <ComboBox x:Name="cmbRoom"
                  Height="48"
                  FontSize="15"
                  materialDesign:HintAssist.Hint="Выберите свободное помещение" />

                <!-- Даты начала и окончания -->
                <Grid Margin="0,20,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,10,0">
                        <TextBlock Text="Дата начала" FontSize="14" Margin="0,0,0,6"/>
                        <DatePicker x:Name="dpStart" Height="48" FontSize="15"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Margin="10,0,0,0">
                        <TextBlock Text="Дата окончания" FontSize="14" Margin="0,0,0,6"/>
                        <DatePicker x:Name="dpEnd" Height="48" FontSize="15"/>
                    </StackPanel>
                   
                </Grid>
                <CheckBox x:Name="chkApproved"
                   Content="Утверждён"
                   Margin="0,20,0,0" FontSize="15"
                   Style="{StaticResource MaterialDesignCheckBox}"/>
                <!-- Кнопки сохранения -->
                <Grid Margin="0,25,0,0">
                    <Button Content="Сохранить изменения"
                        Grid.Column="0"
                        Height="52"
                        Margin="0,0,10,0"
                        Background="#FF2196F3"
                        Click="Save_Click" VerticalAlignment="Top"/>
                </Grid>
            </StackPanel>
        </Border>
    </Grid>
</Window>

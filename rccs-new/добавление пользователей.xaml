<Window x:Class="rccs_new.добавление_пользователей"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Добавление работника"
        Height="633"
        Width="420"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5">

    <Grid Margin="0,0,0,0">
        <Border Width="360"
                Height="588"
                Padding="30"
                CornerRadius="15"
                Background="White"
                VerticalAlignment="Top"
                HorizontalAlignment="Center" Margin="0,10,0,0">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" Opacity="0.15"/>
            </Border.Effect>

            <StackPanel Margin="0,0,0,-20">
                <TextBlock Text="Добавление работника"
                           FontSize="20"
                           FontWeight="SemiBold"
                           Margin="0,0,0,25"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="ФИО" FontSize="14" Margin="0,0,0,0"/>

                <Grid >
                    <Border CornerRadius="10" Background="#F8F8F8" BorderBrush="#CCCCCC" BorderThickness="1">
                        <TextBox  x:Name="txtFIO" TextWrapping="Wrap" Text="" Height="30" FontSize="15"  Background="Transparent"  BorderThickness="0" BorderBrush="#CCCCCC"/>
                    </Border>
                </Grid>

                <TextBlock Text="Дата трудоустройства" FontSize="14" Margin="0,12,0,0"/>


                <Grid>
                    <Border CornerRadius="10" Background="#F8F8F8" BorderBrush="#CCCCCC" BorderThickness="1">

                        <DatePicker x:Name="dpDate" 
                            Height="30" 
                            FontSize="15"
                            Background="Transparent"
                            BorderBrush="#CCCCCC"
                            BorderThickness="0"
                            SelectedDateFormat="Short" Language="ru-RU" Cursor=""/>
                    </Border>
                </Grid>
                <TextBlock Text="Телефон" FontSize="14" Margin="0,12,0,0"/>
                <Grid>
                    <Border CornerRadius="10" Background="#F8F8F8" BorderBrush="#CCCCCC" BorderThickness="1">
                        <TextBox  x:Name="txtPhone" TextWrapping="Wrap" Text="" Height="30" FontSize="15"  Background="Transparent"  BorderThickness="0" BorderBrush="#CCCCCC"/>
                    </Border>
                </Grid>
                <TextBlock Text="Компания" FontSize="14" Margin="0,12,0,0"/>
                <Grid>
                    <Border CornerRadius="10" Background="#F8F8F8" BorderBrush="#CCCCCC" BorderThickness="1">

                        <ComboBox x:Name="cmbComp" Height="30" FontSize="15"
                    Background="Transparent"
                    BorderBrush="#CCCCCC"
                    BorderThickness="0"/>
                    </Border>
                </Grid>
                <TextBlock Text="Роль" FontSize="14" Margin="0,12,0,0"/>
                <Grid>
                    <Border CornerRadius="10" Background="#F8F8F8" BorderBrush="#CCCCCC" BorderThickness="1">

                        <ComboBox x:Name="cmbRole" Height="30" FontSize="15"
                                    Background="Transparent"
                                    BorderBrush="#CCCCCC"
                                    BorderThickness="0"/>
                    </Border>
                </Grid>

                <TextBlock Text="Логин" FontSize="14" Margin="0,12,0,0"/>

                <Grid>
                    <Border CornerRadius="10" Background="#F8F8F8" BorderBrush="#CCCCCC" BorderThickness="1">
                        <TextBox  x:Name="txtLogin" TextWrapping="Wrap" Text="" Height="30" FontSize="15"  Background="Transparent"  BorderThickness="0" BorderBrush="#CCCCCC"/>
                    </Border>
                </Grid>

                <TextBlock Text="Пароль" FontSize="14" Margin="0,12,0,0"/>
                <Grid>
                    <Border CornerRadius="10" Background="#F8F8F8" BorderBrush="#CCCCCC" BorderThickness="1">
                        <TextBox  x:Name="txtPassword" TextWrapping="Wrap" Text="" Height="30" FontSize="15"  Background="Transparent"  BorderThickness="0" BorderBrush="#CCCCCC"/>
                    </Border>
                </Grid>

                <Button Content="Добавить"
                        Height="43"
                        Margin="0,25,0,0"
                        Background="#2196F3"
                        Foreground="White"
                        FontSize="15"
                        FontWeight="Medium"
                        BorderThickness="10"
                        Click="Button_Click"/>

            </StackPanel>
        </Border>

    </Grid>

</Window>
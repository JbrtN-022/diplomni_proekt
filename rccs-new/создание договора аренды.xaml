<Window x:Class="rccs_new.создание_договора_аренды"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Оформление договора аренды" 
        Height="700" 
        Width="1000"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5">

    <Grid>
        
        <Grid Background="#FF2196F3" Height="80" VerticalAlignment="Top">
            <TextBlock Text="Оформление договора аренды"
                       Foreground="White"
                       FontSize="26"
                       FontWeight="Medium"
                       VerticalAlignment="Center"
                       Margin="35,0,0,0"/>

            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Margin="0,0,30,0">

                
                <Border CornerRadius="10" Background="#FFFFFF" BorderBrush="#FF2196F3" BorderThickness="2" 
                        Width="280" Height="48" Margin="0,0,15,0" Padding="8">
                    <ComboBox x:Name="cmbDraft" 
                              FontSize="15"
                              VerticalAlignment="Center"
                              materialDesign:HintAssist.Hint="Выбрать черновик"
                              DisplayMemberPath="display_name"
                              SelectedValuePath="id_license_agreement"
                              SelectionChanged="cmbDraft_SelectionChanged"/>
                </Border>

                <Button x:Name="Back"
                        Style="{StaticResource MaterialDesignToolButton}"
                        Width="50" Height="50"
                        ToolTip="Назад"
                        Click="Back_Click">
                    <materialDesign:PackIcon Kind="ArrowBack" Width="28" Height="28" Foreground="White"/>
                </Button>
            </StackPanel>
        </Grid>

        <Grid Margin="0,90,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="450"/>
                <ColumnDefinition Width="*"/>
               
            </Grid.ColumnDefinitions>

            
            <Border Grid.Column="0" Margin="25,10,15,10" 
                    Padding="25" CornerRadius="15" Background="White">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="15" Opacity="0.12"/>
                </Border.Effect>

                <StackPanel>
                    <TextBlock Text="Номер договора" FontSize="15" Margin="0,0,0,6" FontWeight="Medium"/>
                    <TextBox x:Name="txtLicenseNumber" 
                             IsReadOnly="True"
                             FontSize="15" 
                             Height="48"
                             materialDesign:HintAssist.Hint="Автоматически генерируется"/>

                   
                    <TextBlock Text="Контрагент" FontSize="15" Margin="0,18,0,6" FontWeight="Medium"/>
                    <Grid>
                        <ComboBox x:Name="cmbClient" 
                                  Height="48" 
                                  FontSize="15"
                                  materialDesign:HintAssist.Hint="Выберите контрагента"
                                  DropDownOpened="cmbClient_DropDownOpened"/>
                        <Button Width="45" Height="45" HorizontalAlignment="Right" Margin="0,1,0,0"
                                Click="btnAddNewClient_Click" ToolTip="Добавить нового контрагента">
                            <materialDesign:PackIcon Kind="Plus" Width="26" Height="26" Foreground="White" VerticalAlignment="Center" Margin="-10 0 -10 0"/>
                        </Button>
                    </Grid>

                   
                    <TextBlock Text="Этаж" FontSize="15" Margin="0,18,0,6" FontWeight="Medium"/>
                   
                    <ComboBox x:Name="cmbFloor" 
                      Height="48" 
                      FontSize="15"
                      materialDesign:HintAssist.Hint="Выберите этаж" SelectionChanged="cmbFloor_SelectionChanged"
                     />
                   
                    <TextBlock Text="Кабинет / Помещение" FontSize="15" Margin="0,18,0,6" FontWeight="Medium"/>
                    <ComboBox x:Name="cmbRoom" 
                              Height="48" 
                              FontSize="15"
                              materialDesign:HintAssist.Hint="Выберите свободное помещение" SelectionChanged="cmbRoom_SelectionChanged"
                             />

                   
                    <Grid Margin="0,20,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,10,0">
                            <TextBlock Text="Дата начала" FontSize="14" Margin="0,0,0,6"/>
                            <DatePicker x:Name="dpStart" Height="48" FontSize="15"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="10,0,0,0">
                            <TextBlock Text="Дата окончания" FontSize="14" Margin="0,0,0,6"/>
                            <DatePicker x:Name="dpEnd" Height="48" FontSize="15"/>
                        </StackPanel>
                    </Grid>

                  
                    <Grid Margin="0,25,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>
                        <Button Content="Сохранить черновик" 
                                Grid.Column="0" 
                                Height="52" 
                                Margin="0,0,10,0"
                                Background="#FF757575"
                                Click="Save_Click" VerticalAlignment="Top"/>
                        <Button Content="Оформить договор" 
                                Grid.Column="1" 
                                Height="52" 
                                Margin="10,0,0,0"
                                Background="#FF2196F3"
                                Click="Create_Click"/>
                    </Grid>
                </StackPanel>
            </Border>

            
            <Border Grid.Column="1" Margin="10,20,10,20" 
                    Background="White" CornerRadius="12" 
                     Height="520" VerticalAlignment="Top">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="15" Opacity="0.15"/>
                </Border.Effect>
                <Image x:Name="imgFloorPlan" 
                       Stretch="Uniform" 
                       Margin="10"/>
            </Border>
        </Grid>
    </Grid>
</Window>
<Window x:Class="rccs_new.форма_пользователей"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        mc:Ignorable="d"
        Title="Сотрудники"
        Height="550"
        Width="900"
        WindowStartupLocation="CenterScreen"
        >

    <Grid>
        <!-- Шапка -->
        <Grid Background="#FF2196F3" Height="60" VerticalAlignment="Top">
            <TextBlock Text="Сотрудники"
                       Foreground="White"
                       FontSize="22"
                       FontWeight="Medium"
                       VerticalAlignment="Center"
                       Margin="25,0,0,0"/>

            <!-- Панель кнопок -->
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Margin="0,0,20,0">

                <Button x:Name="Back"
                        Style="{StaticResource MaterialDesignToolButton}"
                        Width="45" Height="45"
                        ToolTip="Назад"
                        Margin="5,0" Click="Back_Click"
                        >
                    <materialDesign:PackIcon Kind="ArrowBack" Width="26" Height="26" Foreground="White"/>
                </Button>

                <Button x:Name="UppBtn"
                        Style="{StaticResource MaterialDesignToolButton}"
                        Width="45" Height="45"
                        ToolTip="Редактировать"
                        Margin="5,0" Click="UppBtn_Click">
                    <materialDesign:PackIcon Kind="Pencil" Width="26" Height="26" Foreground="White"/>
                </Button>

                <Button x:Name="DelBtn"
                        Style="{StaticResource MaterialDesignToolButton}"
                        Width="45" Height="45"
                        ToolTip="Удалить"
                        Margin="5,0" Click="DelBtn_Click">
                    <materialDesign:PackIcon Kind="Delete" Width="26" Height="26" Foreground="White"/>
                </Button>

                <Button x:Name="addBtn"
                        Style="{StaticResource MaterialDesignToolButton}"
                        Width="45" Height="45"
                        ToolTip="Добавить запись"
                        Margin="8,0,0,0" Click="addBtn_Click">
                    <materialDesign:PackIcon Kind="Plus" Width="28" Height="28" Foreground="White"/>
                </Button>
            </StackPanel>
        </Grid>

        <!-- Основная область -->
        <Grid Margin="0,60,0,0">
            <DataGrid x:Name="dgSpravochnik"
          Margin="15,15,15,15"
          AutoGenerateColumns="False"
          CanUserAddRows="False"
          CanUserDeleteRows="False"
          CanUserResizeRows="False"
          GridLinesVisibility="None"
          Background="White"
          Foreground="Black"
          
          Style="{StaticResource MaterialDesignDataGrid}"
          SelectionMode="Single"
          SelectionChanged="dgSpravochnik_SelectionChanged">

                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" 
                            Binding="{Binding id_workers}" 
                            Width="80" 
                            IsReadOnly="True"/>

                    <DataGridTextColumn Header="ФИО" 
                            Binding="{Binding name}" 
                            Width="*" 
                            IsReadOnly="True"/>

                    <DataGridTextColumn Header="дата трудоустройства" 
                            Binding="{Binding work_device_data}" 
                            Width="180" 
                            IsReadOnly="True" />

                    <DataGridTextColumn Header="Номер телефона" 
                            Binding="{Binding number}" 
                            Width="150" 
                            IsReadOnly="True"/>

                    <DataGridTextColumn Header="Компания" 
                            Binding="{Binding company}" 
                            Width="*" 
                            IsReadOnly="True"/>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </Grid>
</Window>
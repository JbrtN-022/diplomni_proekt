<Window x:Class="rccs_new.редактирование_контрагентов"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Редактирование контрагента"
        Height="720"
        Width="820"
        WindowStartupLocation="CenterScreen"  Icon="/Рисунок1.png"
        Background="#F5F5F5">

    <Grid>
        <Border Width="760"
                Padding="30"
                CornerRadius="15"
                Background="White"
                VerticalAlignment="Center"
                HorizontalAlignment="Center"
                Margin="0,20,0 0">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" Opacity="0.15"/>
            </Border.Effect>

            <StackPanel>
                <TextBlock Text="Редактирование контрагента"
                           FontSize="21"
                           FontWeight="SemiBold"
                           Margin="0,0,0,25"
                           HorizontalAlignment="Center"
                           Foreground="#212121"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="30"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Левая колонка - Обязательные поля -->
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Название контрагента *" FontSize="14" Margin="0,0,0,6"/>
                        <Border CornerRadius="10" Background="#F8F8F8" BorderBrush="#CCCCCC" BorderThickness="1">
                            <TextBox x:Name="txtName" Height="38" FontSize="15" Padding="12,0" Background="Transparent" BorderThickness="0"/>
                        </Border>

                        <TextBlock Text="Город *" FontSize="14" Margin="0,14,0,6"/>
                        <Border CornerRadius="10" Background="#F8F8F8" BorderBrush="#CCCCCC" BorderThickness="1">
                            <ComboBox x:Name="cmbCity" Height="38" FontSize="15" Background="Transparent" BorderThickness="0" />
                        </Border>

                        <TextBlock Text="Тип лица *" FontSize="14" Margin="0,14,0,6"/>
                        <Border CornerRadius="10" Background="#F8F8F8" BorderBrush="#CCCCCC" BorderThickness="1">
                            <ComboBox x:Name="cmbTypeFace" Height="38" FontSize="15" Background="Transparent" BorderThickness="0"/>
                        </Border>

                        <TextBlock Text="Фактический адрес" FontSize="14" Margin="0,14,0,6"/>
                        <Border CornerRadius="10" Background="#F8F8F8" BorderBrush="#CCCCCC" BorderThickness="1">
                            <TextBox x:Name="txtActualAddress" Height="38" FontSize="15" Padding="12,0" Background="Transparent" BorderThickness="0" TextWrapping="Wrap"/>
                        </Border>

                        <TextBlock Text="Контактное лицо" FontSize="14" Margin="0,14,0,6"/>
                        <Border CornerRadius="10" Background="#F8F8F8" BorderBrush="#CCCCCC" BorderThickness="1">
                            <TextBox x:Name="txtContName" Height="38" FontSize="15" Padding="12,0" Background="Transparent" BorderThickness="0"/>
                        </Border>

                        <TextBlock Text="Телефон контактного лица" FontSize="14" Margin="0,14,0,6"/>
                        <Border CornerRadius="10" Background="#F8F8F8" BorderBrush="#CCCCCC" BorderThickness="1">
                            <TextBox x:Name="txtContPhone" Height="38" FontSize="15" Padding="12,0" Background="Transparent" BorderThickness="0"/>
                        </Border>
                    </StackPanel>

                    <!-- Правая колонка - Дополнительные поля -->
                    <Grid Grid.Column="2">
                        <StackPanel>
                            <TextBlock Text="Юридический адрес" FontSize="14" Margin="0,0,0,6"/>
                            <Border CornerRadius="10" Background="#F8F8F8" BorderBrush="#CCCCCC" BorderThickness="1">
                                <TextBox x:Name="txtLegalAddress" Height="30" FontSize="15" Padding="12,0" Background="Transparent" BorderThickness="0" TextWrapping="Wrap"/>
                            </Border>

                            <TextBlock Text="E-mail" FontSize="14" Margin="0,14,0,6"/>
                            <Border CornerRadius="10" Background="#F8F8F8" BorderBrush="#CCCCCC" BorderThickness="1">
                                <TextBox x:Name="txtEmail" Height="38" FontSize="15" Padding="12,0" Background="Transparent" BorderThickness="0"/>
                            </Border>

                            <TextBlock Text="ИНН" FontSize="14" Margin="0,14,0,6"/>
                            <Border CornerRadius="10" Background="#F8F8F8" BorderBrush="#CCCCCC" BorderThickness="1">
                                <TextBox x:Name="txtINN" Height="38" FontSize="15" Padding="12,0" Background="Transparent" BorderThickness="0"/>
                            </Border>

                            <TextBlock Text="БИК" FontSize="14" Margin="0,14,0,6"/>
                            <Border CornerRadius="10" Background="#F8F8F8" BorderBrush="#CCCCCC" BorderThickness="1">
                                <TextBox x:Name="txtBIC" Height="38" FontSize="15" Padding="12,0" Background="Transparent" BorderThickness="0"/>
                            </Border>

                            <TextBlock Text="Веб-сайт" FontSize="14" Margin="0,14,0,6"/>
                            <Border CornerRadius="10" Background="#F8F8F8" BorderBrush="#CCCCCC" BorderThickness="1">
                                <TextBox x:Name="txtWebPage" Height="38" FontSize="15" Padding="12,0" Background="Transparent" BorderThickness="0"/>
                            </Border>
                        </StackPanel>
                    </Grid>
                </Grid>

                <!-- Кнопка -->
                <Button Content="Отредактировать"
                        Height="48"
                        Margin="0,25,0,0"
                        Background="#2196F3"
                        Foreground="White"
                        FontSize="15"
                        FontWeight="Medium"
                        Click="Button_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
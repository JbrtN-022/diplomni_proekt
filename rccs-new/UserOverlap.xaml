<Window x:Class="rccs_new.UserOverlap"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="UserOverlap" 
        Height="220" 
        Width="250"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5">

    <Grid Margin="15">
        <!-- Иконка редактирования в правом верхнем углу -->
        
        <Button x:Name="редактировать" Style="{StaticResource MaterialDesignFlatButton}"
         Width="20" 
         Height="20"
         HorizontalAlignment="Right"
         VerticalAlignment="Top"
         Margin="0,5,30,0"
        
         CommandParameter="Left" Padding="0 0 0 0" Click="пользователь_Click" Cursor="Hand" >
            <materialDesign:PackIcon Kind="Pencil" Width="15" Height="20" VerticalAlignment="Center" Foreground="#FF555555"/>
        </Button>
        <Button x:Name="закрыть" Style="{StaticResource MaterialDesignFlatButton}"
         Width="20" 
         Height="20"
         HorizontalAlignment="Right"
         VerticalAlignment="Top"
         Margin="0,5,5,0"

         CommandParameter="Left" Padding="0 0 0 0"  Cursor="Hand" Click="закрыть_Click" >
            
            <materialDesign:PackIcon Kind="Close" Width="15" Height="20" VerticalAlignment="Center" Foreground="#FF555555"/>

        </Button>
        
        <StackPanel Margin="0,20,0,0">

            <!-- Логин -->
            <TextBlock Text="Логин" 
                       FontSize="14" 
                       Margin="5,0,0,6"
                       Foreground="#555"/>

            <Border CornerRadius="10" 
                    Background="#F8F8F8" 
                    BorderBrush="#CCCCCC" 
                    BorderThickness="1">
                <TextBox x:Name="txtLogin" 
                         Height="37" 
                         FontSize="15"
                         Padding="8,0"
                         Background="Transparent" 
                         BorderThickness="0"/>
            </Border>

            <!-- Пароль -->
            <TextBlock Text="Пароль" 
                       FontSize="14" 
                       Margin="5,13,0,6"
                       Foreground="#555"/>

            <Border CornerRadius="10" 
                    Background="#F8F8F8" 
                    BorderBrush="#CCCCCC" 
                    BorderThickness="1">
                <TextBox x:Name="txtPassword" 
                         Height="37" 
                         FontSize="15"
                         Padding="8,0"
                         Background="Transparent" 
                         BorderThickness="0"/>
            </Border>

        </StackPanel>
    </Grid>
</Window>
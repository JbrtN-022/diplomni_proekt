<Window x:Class="rccs_new.форма_бухгалтера"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Панель бухгалтера"
        Height="650"
        Width="1100"
        WindowStartupLocation="CenterScreen"
       
        Background="White">

    <materialDesign:DrawerHost x:Name="DrawerHost" IsLeftDrawerOpen="False">

        <materialDesign:DrawerHost.LeftDrawerContent>
            <StackPanel Width="280" Background="{DynamicResource MaterialDesignPaper}">
                <TextBlock Text="Меню бухгалтера"
                           FontSize="20"
                           FontWeight="SemiBold"
                           Margin="20,30,20,25"
                           Foreground="{DynamicResource PrimaryHueMidBrush}"/>

                <StackPanel Margin="15,0">


                    
                    <Button x:Name="контрагенты"
                            Content="Список контрагентов"
                            Height="45"
                            Margin="5,8"
                    Style="{StaticResource MaterialDesignRaisedButton}" Click="контрагенты_Click"  />
                    <Button x:Name="Просмотр_договоров_аренды"
                             Content="Список договоров аренды"
                             Height="45"
                             Margin="5,8"
                     Style="{StaticResource MaterialDesignRaisedButton}" Click="Просмотр_договоров_аренды_Click"  />
                    <Button x:Name="печать"
                            Content="Распечатать договор ТС"
                            Height="45"
                            Margin="5,8"
                    Style="{StaticResource MaterialDesignRaisedButton}" Click="печать_Click"   />
                    <Button x:Name="выйти" Content="Выйти"
                            Height="45"
                            Margin="5,15,5,5"
                            Style="{StaticResource MaterialDesignFlatButton}" Click="выйти_Click" />
                </StackPanel>
            </StackPanel>
        </materialDesign:DrawerHost.LeftDrawerContent>

        <Grid RenderTransformOrigin="0.502,0.474">
            <Image Width="480"
                   HorizontalAlignment="Right"
                   VerticalAlignment="Stretch"
                   Source="/4341e5ebee5ed500e1fb2f79340f0d53.jpg"
                   Stretch="UniformToFill"
                   Opacity="1"/>

            <StackPanel Margin="90,40,0,0" 
                        VerticalAlignment="Top" 
                        HorizontalAlignment="Left">
                <TextBlock x:Name="title" 
                           Text="С возвращением,"
                           FontSize="32"
                           FontWeight="Medium"
                           TextWrapping="Wrap"
                           MaxWidth="524"
                           Foreground="#212121" 
                           />
            </StackPanel>

            <Button Style="{StaticResource MaterialDesignFlatButton}"
                    Width="50" 
                    Height="50"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Margin="15"
                    Command="{x:Static materialDesign:DrawerHost.OpenDrawerCommand}"
                    CommandParameter="Left">
                <materialDesign:PackIcon Kind="Menu" Width="30" Height="30"/>
            </Button>
            <Button x:Name="пользователь" Style="{StaticResource MaterialDesignFlatButton}"
                    Width="50" 
                    Height="50"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Margin="15 50 15 0"
                   
                    CommandParameter="Left" Padding="0 0 0 0" Click="пользователь_Click" >
                <materialDesign:PackIcon Kind="Account" Width="25" Height="40" VerticalAlignment="Center"/>
            </Button>
            <Border Height="25"
                    VerticalAlignment="Bottom"
                    Background="#2196F3" Panel.ZIndex="-1"/>
        </Grid>
    </materialDesign:DrawerHost>
</Window>
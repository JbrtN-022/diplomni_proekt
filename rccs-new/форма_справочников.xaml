<Window x:Class="rccs_new.форма_справочников"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Справочники"
        Height="580"
        Width="920"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <!-- Шапка -->
        <Grid Background="#FF2196F3" Height="60" VerticalAlignment="Top">
            <TextBlock Text="Справочники"
                       Foreground="White"
                       FontSize="22"
                       FontWeight="Medium"
                       VerticalAlignment="Center"
                       Margin="25,0,0,0"/>

            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Margin="0,0,20,0">

                <Button x:Name="Back"
                        Style="{StaticResource MaterialDesignToolButton}"
                        Width="45" Height="45"
                        ToolTip="Назад"
                        Margin="5,0"
                        Click="Back_Click">
                    <materialDesign:PackIcon Kind="ArrowBack" Width="26" Height="26" Foreground="White"/>
                </Button>

                <Button x:Name="DelBtn"
                        Style="{StaticResource MaterialDesignToolButton}"
                        Width="45" Height="45"
                        ToolTip="Удалить"
                        Margin="5,0" Click="DelBtn_Click">
                    <materialDesign:PackIcon Kind="Delete" Width="26" Height="26" Foreground="White"/>
                </Button>
            </StackPanel>
        </Grid>

        <!-- Основная область -->
        <Grid Margin="0,60,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="340"/>
                <ColumnDefinition Width="175*"/>
                <ColumnDefinition Width="304*"/>
                <ColumnDefinition Width="101*"/>
            </Grid.ColumnDefinitions>

            <!-- Левая колонка - ComboBox -->
            <StackPanel Margin="25,25,15,0">
                <TextBlock Text="Выберите справочник:"
                           FontSize="16"
                           FontWeight="Medium"
                           Margin="0,0,0,10"/>

                <Grid>
                    <Border CornerRadius="10" Background="#F8F8F8" BorderBrush="#CCCCCC" BorderThickness="1">

                        <ComboBox x:Name="cmbSpravochnik" Height="35" FontSize="15"
                    Background="Transparent"
                    BorderBrush="#CCCCCC"
                    BorderThickness="0" SelectionChanged="cmbSpravochnik_SelectionChanged"
                                  />
                    </Border>
                </Grid>
                <Border x:Name="Add" Width="290"
                Padding="15"
                CornerRadius="15"
                Background="White"
                VerticalAlignment="Center"
                HorizontalAlignment="Center"
                Margin="0,10,0,0" 
                BorderBrush="#FFCCCCCC"
                BorderThickness="1"
>

                    <StackPanel>
                        <TextBlock Text="Добавление записи"
                           FontSize="16"
                           FontWeight="Medium"
                           Margin="0,0,0,15"
                           HorizontalAlignment="Center"/>


                        <TextBlock x:Name="addtxt" Text="Пароль" FontSize="14" Margin="0,0,0,5"/>
                        <Border CornerRadius="10" Background="#F8F8F8" BorderBrush="#CCCCCC" BorderThickness="1">
                            <TextBox x:Name="txtAdd" 
                             Height="33" 
                             FontSize="15"
                             Padding="10,0"
                             Background="Transparent" 
                             BorderThickness="0"
                             Foreground="Black"/>
                        </Border>

                        <Button Content="Добавление"
                        Height="45"
                        Margin="0,15,0,0"
                        Background="#2196F3"
                        Foreground="White"
                        FontSize="15"
                        FontWeight="Medium"
                        BorderThickness="0" Click="Button_Click"
                       />
                    </StackPanel>
                </Border>
                <Border x:Name="Upp" Width="290"
                Padding="15"
                CornerRadius="15"
                Background="White"
                VerticalAlignment="Center"
                HorizontalAlignment="Center"
                Margin="0,10,0,0" 
                BorderBrush="#FFCCCCCC"
                BorderThickness="1"
>

                    <StackPanel>
                        <TextBlock Text="Редактирование записи"
                           FontSize="16"
                           FontWeight="Medium"
                           Margin="0,0,0,15"
                           HorizontalAlignment="Center"/>


                        <TextBlock x:Name="upptxt" Text="Пароль" FontSize="14" Margin="0,0,0,5"/>
                        <Border CornerRadius="10" Background="#F8F8F8" BorderBrush="#CCCCCC" BorderThickness="1">
                            <TextBox x:Name="txtUpp" 
                             Height="33" 
                             FontSize="15"
                             Padding="10,0"
                             Background="Transparent" 
                             BorderThickness="0"
                             Foreground="Black"/>
                        </Border>

                        <Button Content="Сохранить изменения"
                        Height="45"
                        Margin="0,15,0,0"
                        Background="#2196F3"
                        Foreground="White"
                        FontSize="15"
                        FontWeight="Medium"
                        BorderThickness="0" Click="Button_Click_1"
                        />
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- Правая колонка - Таблица -->
            <DataGrid x:Name="dgSpravochnik"
                      Grid.Column="1"
                      Margin="10,25,35,20"
                      
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      CanUserResizeRows="False"
                      GridLinesVisibility="Horizontal"
                      AutoGenerateColumns="True"
                      Background="#F8F8F8"
                      Foreground="Black"
                      BorderBrush="#CCCCCC"
                      BorderThickness="1"
                      SelectionMode="Single"
                      Style="{StaticResource MaterialDesignDataGrid}" SelectionChanged="dgSpravochnik_SelectionChanged" Grid.ColumnSpan="3">

                <DataGrid.Columns>
                    <DataGridTextColumn Header="Ключ"
                                        Binding="{Binding Code}"
                                        Width="130"
                                        IsReadOnly="True"/>

                    <DataGridTextColumn Header="Наименование"
                                        Binding="{Binding Name}"
                                        Width="*"
                                        IsReadOnly="True"/>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </Grid>
</Window>
<Window x:Class="rccs_new.форма_справочников"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Справочники"
        Height="580"
        Width="920"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <!-- Шапка -->
        <Grid Background="#FF2196F3" Height="60" VerticalAlignment="Top">
            <TextBlock Text="Справочники"
                       Foreground="White"
                       FontSize="22"
                       FontWeight="Medium"
                       VerticalAlignment="Center"
                       Margin="25,0,0,0"/>

            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Margin="0,0,20,0">

                <Button x:Name="Back"
                        Style="{StaticResource MaterialDesignToolButton}"
                        Width="45" Height="45"
                        ToolTip="Назад"
                        Margin="5,0"
                        Click="Back_Click">
                    <materialDesign:PackIcon Kind="ArrowBack" Width="26" Height="26" Foreground="White"/>
                </Button>

                <Button x:Name="UppBtn"
                        Style="{StaticResource MaterialDesignToolButton}"
                        Width="45" Height="45"
                        ToolTip="Редактировать"
                        Margin="5,0">
                    <materialDesign:PackIcon Kind="Pencil" Width="26" Height="26" Foreground="White"/>
                </Button>

                <Button x:Name="DelBtn"
                        Style="{StaticResource MaterialDesignToolButton}"
                        Width="45" Height="45"
                        ToolTip="Удалить"
                        Margin="5,0">
                    <materialDesign:PackIcon Kind="Delete" Width="26" Height="26" Foreground="White"/>
                </Button>

                <Button x:Name="addBtn"
                        Style="{StaticResource MaterialDesignToolButton}"
                        Width="45" Height="45"
                        ToolTip="Добавить запись"
                        Margin="8,0,0,0">
                    <materialDesign:PackIcon Kind="Plus" Width="28" Height="28" Foreground="White"/>
                </Button>
            </StackPanel>
        </Grid>

        <!-- Основная область -->
        <Grid Margin="0,60,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="340"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Левая колонка - ComboBox -->
            <StackPanel Margin="25,25,15,0">
                <TextBlock Text="Выберите справочник:"
                           FontSize="16"
                           FontWeight="Medium"
                           Margin="0,0,0,10"/>
                <ComboBox x:Name="cmbSpravochnik"
                          Height="45"
                          FontSize="15"
                          
                          SelectionChanged="cmbSpravochnik_SelectionChanged"/>
            </StackPanel>

            <!-- Правая колонка - Таблица -->
            <DataGrid x:Name="dgSpravochnik"
                      Grid.Column="1"
                      Margin="15,25,25,25"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      CanUserResizeRows="False"
                      GridLinesVisibility="Horizontal"
                      Background="#FF96D1FF"
                      Foreground="Black"
                      BorderBrush="#2196F3"
                      BorderThickness="1"
                      SelectionMode="Single"
                      Style="{StaticResource MaterialDesignDataGrid}">

                <DataGrid.Columns>
                    <DataGridTextColumn Header="Ключ"
                                        Binding="{Binding Code}"
                                        Width="130"
                                        IsReadOnly="True"/>

                    <DataGridTextColumn Header="Наименование"
                                        Binding="{Binding Name}"
                                        Width="*"
                                        IsReadOnly="True"/>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </Grid>
</Window>
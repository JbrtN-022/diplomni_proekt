<Window x:Class="rccs_new.Форма_оформления_лицензии"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Оформление новой лицензии" 
        Height="720" 
        Width="750"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <!-- Шапка -->
        <Grid Background="#FF2196F3" Height="70" VerticalAlignment="Top">
            <TextBlock Text="Оформление новой лицензии"
                       Foreground="White"
                       FontSize="24"
                       FontWeight="Medium"
                       VerticalAlignment="Center"
                       Margin="30,0,0,0"/>
            <StackPanel Orientation="Horizontal"
            HorizontalAlignment="Right"
            VerticalAlignment="Center"
            Margin="0,0,20,0">
                <Border CornerRadius="10" BorderThickness="1" BorderBrush="White" Background="White" Width="200" Margin=" 0 0 10 0" Padding=" 5" Height="40">
                    <!--<ComboBox x:Name="cmbDraft" FontSize="15"
                              BorderBrush=" Transparent" Foreground="#FF2196F3" materialDesign:HintAssist.Hint="Выберите лицензию" 
            Cursor="" SelectionChanged="cmbDraft_SelectionChanged"/>-->
                    <ComboBox x:Name="cmbDraft" VerticalAlignment="Top"  Margin=" 0 -3 0 0" DisplayMemberPath="display_name"  
                              SelectedValuePath="id_license_agreement" SelectionChanged="cmbDraft_SelectionChanged"/>
                </Border>
            <Button x:Name="Back"
                        Style="{StaticResource MaterialDesignToolButton}"
                        Width="45" Height="45"
                        ToolTip="Назад"
                        Margin="5,0" Click="Back_Click"
                        >
                <materialDesign:PackIcon Kind="ArrowBack" Width="26" Height="26" Foreground="White"/>
            </Button>
            </StackPanel>
        </Grid>

        <StackPanel Margin="30,80,20,20" HorizontalAlignment="Center" >

            <!-- Номер лицензии -->
            <TextBlock Text="Номер лицензии" FontSize="15" Margin="0,0,0,5"/>
            <TextBox x:Name="txtLicenseNumber" 
                     IsReadOnly="True"
                     FontSize="18"
                     Height="40"
                     materialDesign:HintAssist.Hint="Автоматически генерируется"/>

            <!-- Контрагент -->
            <TextBlock Text="Контрагент" FontSize="15" Margin="0,10,0,5"/>
            <Grid>
                <ComboBox x:Name="cmbClient" 
                          Height="40"
                          FontSize="15"
                          materialDesign:HintAssist.Hint="Выберите контрагента"
                          DropDownOpened="cmbClient_DropDownOpened"/>

                <Button 
                        Width="40" 
                        Height="40"
                        HorizontalAlignment="Right"
                        Margin="0,0,0,0"
                        Click="btnAddNewClient_Click">
                    <materialDesign:PackIcon Kind="Plus" Width="26" Height="26" Foreground="White" VerticalAlignment="Center" Margin="-10 0 -10 0"/>
                </Button>
            </Grid>
            <TextBlock Text="Программа" FontSize="15" Margin="0,10,0,5"/>
            <ComboBox x:Name="cmbProgram" 
                      Height="40"
                      FontSize="15"
                      materialDesign:HintAssist.Hint="Выберите программу"
                     />

            <!-- Услуги -->
            <TextBlock Text="Услуги по лицензии" FontSize="15" Margin="0,10,0,8"/>
            <DataGrid x:Name="dgAllServices"
                      Height="180"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False" Foreground="Black"  >
                <DataGrid.Columns>
                    <DataGridCheckBoxColumn Header="Выбрать" 
                                            Binding="{Binding IsSelected}" 
                                            Width="100" />
                    <DataGridTextColumn Header="Название услуги" 
                                        Binding="{Binding Name}" 
                                        Width="*" IsReadOnly="True"/>
                    <DataGridComboBoxColumn Header="Работник"
                        Width="200"
                        SelectedValueBinding="{Binding IdWorker, Mode=TwoWay}"
                        DisplayMemberPath="name"
                        SelectedValuePath="id_workers"/>
                    <DataGridTextColumn Header="Количество" 
                                             Binding="{Binding Quantity, Mode=TwoWay}" 
                                             Width="150" IsReadOnly="False"/>
                </DataGrid.Columns>
            </DataGrid>

            <!-- Даты -->
            <Grid Margin="0,20,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,15,0">
                    <TextBlock Text="Дата начала действия" FontSize="14" Margin="0,0,0,5"/>
                    <DatePicker x:Name="dpStart" Height="40" FontSize="15" Language="ru-RU"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="15,0,0,0">
                    <TextBlock Text="Дата окончания действия" FontSize="14" Margin="0,0,0,5"/>
                    <DatePicker x:Name="dpEnd" Height="40" FontSize="15" Language="ru-RU"/>
                </StackPanel>
            </Grid>

            <!-- Кнопка создания -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Margin="0,0,15,0">
                <Button Content="Сохранить в черновики"
                    Height="52"
                    Margin="0,20,0,0"
                    FontSize="16"
                    FontWeight="Medium"
                    Background="#FF2196F3"
                    Click="Save_Click"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Margin="15,0,0,0">
                        <Button Content="Оформить лицензию"
                    Height="52"
                    Margin="0,20,0,0"
                    FontSize="16"
                    FontWeight="Medium"
                    Background="#FF2196F3"
                    Click="Create_Click"/>
                    </StackPanel>
            </Grid>
            
        </StackPanel>
    </Grid>
</Window>
<UserControl x:Class="rccs_new.UserControlLicenseAgreement"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
            xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
            xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
            xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
            xmlns:local="clr-namespace:rccs_new"
             Width="520" Height="260">

    <Border Margin="8" Background="White" CornerRadius="12" BorderBrush="#E0E0E0" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="12" Opacity="0.13"/>
        </Border.Effect>

        <Grid Margin="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Левая часть - основная информация -->
            <StackPanel Grid.Column="0" MouseLeftButtonDown="StackPanel_MouseLeftButtonDown">
                <!-- Номер договора + Название контрагента -->
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Договор №" FontSize="15" FontWeight="SemiBold"/>
                    <TextBlock x:Name="txtLicenseId" Text="00000" FontSize="15" FontWeight="SemiBold" Foreground="#FF2196F3" Margin="4,0,0,0"/>
                </StackPanel>

                <TextBlock x:Name="txtCounterparty" 
                           Text="Контрагент: " 
                           FontSize="16" 
                           FontWeight="Medium"
                           TextWrapping="Wrap"
                           Margin="0,6,0,0"/>

                <TextBlock x:Name="txtProgram" 
                           Text="Программа: " 
                           FontSize="14" 
                           Foreground="#444"
                           Margin="0,4,0,0"/>
                <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                    <TextBlock Text="С" FontSize="13" Foreground="#666"/>
                    <TextBlock x:Name="txtDateFrom" Text="01.01.2025" Margin="6,0,0,0" FontSize="13"/>
                    <TextBlock Text="по" Margin="8,0,0,0" FontSize="13" Foreground="#666"/>
                    <TextBlock x:Name="txtDateUntil" Text="31.12.2025" Margin="6,0,0,0" FontSize="13"/>
                </StackPanel>

                <TextBlock Text="Дата заключения" FontSize="12" Foreground="#777" Margin="0,8,0,2"/>
                <TextBlock x:Name="txtConclusionDate" Text="15.03.2025" FontSize="13" Foreground="#333"/>
                <TextBlock x:Name="txtWorker" Text="Ответственный: Иванов И.И." FontSize="13" Foreground="#555" Margin="0,10,0,0"/>

                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                    <TextBlock Text="Статус:" FontSize="13" Foreground="#666"/>
                    <TextBlock x:Name="txtApproved" Text="Утверждён" Margin="8,0,0,0" FontSize="13" FontWeight="Medium" Foreground="#4CAF50"/>
                </StackPanel>
            </StackPanel>
            <Border Grid.Column="1" Margin="0,0,0,0" BorderBrush="#FFCCCCCC" BorderThickness="1" CornerRadius="8" Background="#F9F9F9">
                <ScrollViewer VerticalScrollBarVisibility="Auto" >
                    <StackPanel Margin="10">
                        <TextBlock Text="Услуги по договору:" 
                                   FontSize="13" 
                                   FontWeight="Medium"
                                   Foreground="#444"
                                   Margin="0,0,0,8"/>
                        <TextBlock x:Name="txtServicesList" 
                                   Text="• Услуга 1&#10;• Услуга 2&#10;• Услуга 3"
                                   FontSize="13"
                                   TextWrapping="Wrap"
                                   Foreground="#333"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Border>
</UserControl>
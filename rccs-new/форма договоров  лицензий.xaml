<Window x:Class="rccs_new.форма_договоров__лицензий"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Просмотр договоров и лицензий"
        Height="760"
        Width="1320"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5">

    <Grid>
        <!-- Шапка -->
        <Grid Background="#FF2196F3" Height="80" VerticalAlignment="Top">
            <TextBlock Text="Просмотр договоров аренды и лицензий на ПО"
                       Foreground="White"
                       FontSize="26"
                       FontWeight="Medium"
                       VerticalAlignment="Center"
                       Margin="35,0,0,0"/>

            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Margin="0,0,30,0">
                <Button x:Name="Back"
                        Style="{StaticResource MaterialDesignToolButton}"
                        Width="52" Height="52"
                        Margin="0,0,15,0"
                        Click="Back_Click"
                        ToolTip="Назад">
                    <materialDesign:PackIcon Kind="ArrowBack" Width="28" Height="28" Foreground="White"/>
                </Button>
            </StackPanel>
        </Grid>

        <!-- Основное содержимое -->
        <Grid Margin="0,90,0,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Панель фильтров (3 колонки) -->
            <Border Grid.Row="0" Margin="25,10,25,15" Padding="25" 
                    Background="White" CornerRadius="12">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="12" Opacity="0.12"/>
                </Border.Effect>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="420"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- 1. Тип документа -->
                    <StackPanel Grid.Column="0" Margin="0,0,40,0">
                        <TextBlock Text="Тип документа" FontSize="14" Margin="0,0,0,8" FontWeight="Medium"/>
                        <ComboBox x:Name="cmbDocumentType" 
                                  Width="280" Height="40" FontSize="15"
                                  materialDesign:HintAssist.Hint="Выберите тип"
                                  SelectionChanged="cmbDocumentType_SelectionChanged">
                            <ComboBoxItem Content="Договор аренды"/>
                            <ComboBoxItem Content="Лицензия на ПО"/>
                        </ComboBox>
                    </StackPanel>

                    <!-- 2. Выбор документа + чекбокс -->
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="Документ" FontSize="14" Margin="0,0,0,8" FontWeight="Medium"/>
                        <ComboBox x:Name="cmbDocumentList" 
                                  Width="400" Height="40" FontSize="15"
                                  materialDesign:HintAssist.Hint="Выберите документ"
                                  SelectionChanged="cmbDocumentList_SelectionChanged"/>

                        <!-- Чекбокс под комбобоксом -->
                        <CheckBox x:Name="chkOnlyApproved"
                                  Content="Показывать только утверждённые документы"
                                  Margin="5,12,0,0"
                                  Style="{StaticResource MaterialDesignCheckBox}"
                                  Checked="chkOnlyApproved_Checked"
                                  Unchecked="chkOnlyApproved_Unchecked"/>
                    </StackPanel>

                    <!-- 3. Кнопки действий -->
                    <StackPanel Grid.Column="2" VerticalAlignment="Bottom" Margin="240,0,0,25" Orientation="Horizontal">
                        <Button x:Name="btnEdit"
                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                Width="52" Height="52" Margin="8,0"
                                ToolTip="Редактировать"
                                Click="btnEdit_Click">
                            <materialDesign:PackIcon Kind="Pencil" Width="26" Height="26" Margin="-8 0"/>
                        </Button>

                        <Button x:Name="btnDelete"
                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                Width="52" Height="52" Margin="8,0"
                                ToolTip="Удалить"
                                Click="btnDelete_Click">
                            <materialDesign:PackIcon Kind="Delete" Width="26" Height="26" Margin="-8 0"/>
                        </Button>

                        <Button x:Name="btnPrint"
                                Style="{StaticResource MaterialDesignRaisedButton}"
                                Width="52" Height="52" Margin="8,0"
                                Background="#FF2196F3"
                                ToolTip="Печать"
                                Click="btnPrint_Click">
                            <materialDesign:PackIcon Kind="Printer" Width="26" Height="26" Foreground="White" Margin="-8 0"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Карточки -->
           
                <ScrollViewer Grid.Row="1" Margin="25,0,25,25" 
                          VerticalScrollBarVisibility="Auto">
                <Border BorderBrush="#FF2196F3" BorderThickness ="2" CornerRadius="20">
                    <ItemsControl x:Name="itemsControlDocuments">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal"
                                       HorizontalAlignment="Left"
                                       ItemWidth="520"
                                       ItemHeight="245"
                                       Margin="8"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                    </ItemsControl>
                </Border>
            </ScrollViewer>
           
        </Grid>
    </Grid>
</Window>
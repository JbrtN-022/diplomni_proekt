<Window x:Class="rccs_new.форма_договоров__лицензий"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Просмотр договоров и лицензий"
        Height="760"
        Width="1020"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5">

    <Grid>
        <!-- Шапка -->
        <Grid Background="#FF2196F3" Height="80" VerticalAlignment="Top">
            <TextBlock Text="Просмотр договоров аренды и лицензий на ПО"
                       Foreground="White"
                       FontSize="26"
                       FontWeight="Medium"
                       VerticalAlignment="Center"
                       Margin="35,0,0,0"/>

            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Margin="0,0,30,0">
                <Button x:Name="Back"
                        Style="{StaticResource MaterialDesignToolButton}"
                        Width="52" Height="52"
                        Margin="0,0,15,0"
                        Click="Back_Click"
                        ToolTip="Назад">
                    <materialDesign:PackIcon Kind="ArrowBack" Width="28" Height="28" Foreground="White"/>
                </Button>
            </StackPanel>
        </Grid>

        <!-- Основное содержимое -->
        <Grid Margin="0,90,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="450"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Панель фильтров (левая колонка) -->
            <Border Grid.Column="0" Margin="25,10,15,25" Padding="25" 
                    Background="White" CornerRadius="12">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="12" Opacity="0.12"/>
                </Border.Effect>

                <StackPanel>
                    <!-- 1. Тип документа -->
                    <StackPanel Margin="0,0,0,25">
                        <TextBlock Text="Тип документа" FontSize="14" Margin="0,0,0,8" FontWeight="Medium"/>
                        <ComboBox x:Name="cmbDocumentType" 
                                  Width="280" Height="40" FontSize="15"
                                  materialDesign:HintAssist.Hint="Выберите тип"
                                  SelectionChanged="cmbDocumentType_SelectionChanged">
                            <ComboBoxItem Content="Договор аренды"/>
                            <ComboBoxItem Content="Лицензия на ПО"/>
                        </ComboBox>
                    </StackPanel>

                    <!-- 2. Выбор документа -->
                    <StackPanel Margin="0,0,0,25">
                        <TextBlock Text="Документ" FontSize="14" Margin="0,0,0,8" FontWeight="Medium"/>
                        <ComboBox x:Name="cmbDocumentList" 
                                  Width="280" Height="40" FontSize="15"
                                  materialDesign:HintAssist.Hint="Выберите документ"
                                  SelectionChanged="cmbDocumentList_SelectionChanged"/>
                    </StackPanel>

                    <!-- 3. Чекбокс -->
                    <CheckBox x:Name="chkOnlyApproved"
                              Content="Показывать только утверждённые документы"
                              Margin="0,0,0,25"
                              Style="{StaticResource MaterialDesignCheckBox}"
                              Checked="chkOnlyApproved_Checked"
                              Unchecked="chkOnlyApproved_Unchecked"/>

                    <!-- 4. Кнопки действий -->
                    <StackPanel Orientation="Horizontal" Margin="0,30,0,0">
                        <Button x:Name="btnEdit"
                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                Height="40" Margin="0,0,10,0"
                                ToolTip="Редактировать"
                                Click="btnEdit_Click">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Pencil" Width="20" Height="20" Margin="0,0,5,0"/>
                                <TextBlock Text="Изменить"/>
                            </StackPanel>
                        </Button>

                        <Button x:Name="btnDelete"
                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                Height="40" Margin="0,0,10,0"
                                ToolTip="Удалить"
                                Click="btnDelete_Click">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Delete" Width="20" Height="20" Margin="0,0,5,0"/>
                                <TextBlock Text="Удалить"/>
                            </StackPanel>
                        </Button>

                        <Button x:Name="btnPrint"
                                Style="{StaticResource MaterialDesignRaisedButton}"
                                Height="40"
                                Background="#FF2196F3"
                                ToolTip="Печать"
                                Click="btnPrint_Click">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Printer" Width="20" Height="20" Foreground="White" Margin="0,0,5,0"/>
                                <TextBlock Text="Печать" Foreground="White"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Border>

           
            <Border Grid.Column="1" Margin="0,10,25,25" CornerRadius="12" BorderBrush="#FF2196F3">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="itemsControlDocuments">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal"
                                          HorizontalAlignment="Left"
                                          ItemWidth="520"
                                          ItemHeight="245"
                                          Margin="8"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                    </ItemsControl>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</Window>
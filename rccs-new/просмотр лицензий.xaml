<Window x:Class="rccs_new.просмотр_лицензий"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:rccs_new"
         xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        mc:Ignorable="d"  Icon="/Рисунок1.png"
        Title="просмотр_лицензий" Height="680" Width="1000" Cursor="">
    <Grid>

        <Grid Background="#FF2196F3" Height="60" VerticalAlignment="Top">
            <TextBlock Text="Просмотр лицензий"
       Foreground="White"
       FontSize="22"
       FontWeight="Medium"
       VerticalAlignment="Center"
       Margin="25,0,0,0"/>

           
            <StackPanel Orientation="Horizontal"
        HorizontalAlignment="Right"
        VerticalAlignment="Center"
        Margin="0,0,20,0">

                <Button x:Name="Back"
        Style="{StaticResource MaterialDesignToolButton}"
        Width="45" Height="45"
        ToolTip="Назад"
        Margin="5,0" Click="Back_Click"
        >
                    <materialDesign:PackIcon Kind="ArrowBack" Width="26" Height="26" Foreground="White"/>
                </Button>
            </StackPanel>
        </Grid>

        <Grid Margin="0,70,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="380"/>
               
                <ColumnDefinition Width="550"/>
               
            </Grid.ColumnDefinitions>

           
            <Border Margin="20,20,10,20"
                    Padding="25"
                    CornerRadius="15"
                    Background="White">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="15" Opacity="0.15"/>
                </Border.Effect>

                <StackPanel>
                    <TextBlock Text="Фильтры"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Margin="0,0,0,20"
                               HorizontalAlignment="Center"
                               Foreground="#FF2196F3"/>

                    
                    <TextBlock Text="Поиск" FontSize="14" Margin="0,0,0,8"/>
                    <TextBox x:Name="txtSearch"
                             Height="32"
                             FontSize="15"
                             materialDesign:HintAssist.Hint="По номеру договора или названию..."
                             TextChanged="txtSearch_TextChanged"/>

                   
                    <TextBlock Text="Работник" FontSize="14" Margin="0,18,0,8"/>
                    <ComboBox x:Name="cmbWorker"
                              Height="32"
                              FontSize="15"
                              materialDesign:HintAssist.Hint="Выберите работника"
                              SelectionChanged="Filter_SelectionChanged"/>

                   
                    <TextBlock Text="Программа" FontSize="14" Margin="0,18,0,8"/>
                    <ComboBox x:Name="cmbProgram"
                              Height="32"
                              FontSize="15"
                              materialDesign:HintAssist.Hint="Выберите программу"
                              SelectionChanged="Filter_SelectionChanged"/>

                    
                    <TextBlock Text="Дата с" FontSize="14" Margin="0,18,0,8"/>
                    <DatePicker x:Name="dpDateFrom" 
                                Height="32" 
                                FontSize="15"
                                SelectedDateFormat="Short" SelectedDateChanged="dpDateFrom_SelectedDateChanged"/>

                    
                    <TextBlock Text="Дата по" FontSize="14" Margin="0,18,0,8"/>
                    <DatePicker x:Name="dpDateTo" 
                                Height="32" 
                                FontSize="15"
                                SelectedDateFormat="Short" SelectedDateChanged="dpDateTo_SelectedDateChanged"/>

                   
                    <Button Content="Очистить фильтры"
                            Height="30"
                            Margin="0,25,0,0"
                            Background="#FF2196F3"
                            Foreground="#fff"
                            Click="btnClearFilters_Click"/>
                </StackPanel>
            </Border>

           
            <ScrollViewer Grid.Column="1" 
                          Margin="10,20,-60,20"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <ItemsControl x:Name="itemsControlLicenses" Width="570">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Margin="10"
                                       Orientation="Horizontal"
                                       ItemWidth="550"
                                       ItemHeight="260"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>
            </ScrollViewer>
        </Grid>
    </Grid>
</Window>

<Window x:Class="rccs_new.форма_контрагентов"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Контрагенты"
        Height="650"
        Width="880"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5">

    <Grid>
        <Grid Background="#FF2196F3" Height="60" VerticalAlignment="Top">
            <TextBlock Text="Контрагенты"
               Foreground="White"
               FontSize="22"
               FontWeight="Medium"
               VerticalAlignment="Center"
               Margin="25,0,0,0"/>

            <!-- Панель кнопок -->
            <StackPanel Orientation="Horizontal"
                HorizontalAlignment="Right"
                VerticalAlignment="Center"
                Margin="0,0,20,0">

                <Button x:Name="Back"
                Style="{StaticResource MaterialDesignToolButton}"
                Width="45" Height="45"
                ToolTip="Назад"
                Margin="5,0" Click="Back_Click"
                >
                    <materialDesign:PackIcon Kind="ArrowBack" Width="26" Height="26" Foreground="White"/>
                </Button>

                <Button x:Name="UppBtn"
                Style="{StaticResource MaterialDesignToolButton}"
                Width="45" Height="45"
                ToolTip="Редактировать"
                Margin="5,0" Click="UppBtn_Click">
                    <materialDesign:PackIcon Kind="Pencil" Width="26" Height="26" Foreground="White"/>
                </Button>

                <Button x:Name="DelBtn"
                Style="{StaticResource MaterialDesignToolButton}"
                Width="45" Height="45"
                ToolTip="Удалить"
                Margin="5,0" Click="DelBtn_Click">
                    <materialDesign:PackIcon Kind="Delete" Width="26" Height="26" Foreground="White"/>
                </Button>

                <Button x:Name="addBtn"
                Style="{StaticResource MaterialDesignToolButton}"
                Width="45" Height="45"
                ToolTip="Добавить запись"
                Margin="8,0,0,0" Click="addBtn_Click">
                    <materialDesign:PackIcon Kind="Plus" Width="28" Height="28" Foreground="White"/>
                </Button>
            </StackPanel>
        </Grid>

        <Grid Margin="0,70,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="380"/>
                <!-- Панель фильтров -->
                <ColumnDefinition Width="490"/>
                <!-- Карточки -->
            </Grid.ColumnDefinitions>

            <!-- Левая панель фильтров (как в твоём примере) -->
            <Border Margin="20,20,10,20"
                    Padding="25"
                    CornerRadius="15"
                    Background="White">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="15" Opacity="0.15"/>
                </Border.Effect>

                <StackPanel>
                    <TextBlock Text="Фильтры"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Margin="0,0,0,25"
                               HorizontalAlignment="Center"
                               Foreground="#FF2196F3"/>

                    <!-- Поиск -->
                    <TextBlock Text="Поиск" FontSize="14" Margin="0,0,0,8"/>
                    <TextBox x:Name="txtSearch"
                             Height="42"
                             FontSize="15"
                             materialDesign:HintAssist.Hint="Поиск по названию, ИНН, email..."
                             TextChanged="txtSearch_TextChanged"
                             />

                    <!-- Город -->
                    <TextBlock Text="Город" FontSize="14" Margin="0,18,0,8"/>
                    <ComboBox x:Name="cmbCity"
                              Height="42"
                              FontSize="15"
                              materialDesign:HintAssist.Hint="Выберите город" SelectionChanged="Filter_SelectionChanged"
                             
                             />

                    <!-- Тип лица -->
                    <TextBlock Text="Тип лица" FontSize="14" Margin="0,18,0,8"/>
                    <ComboBox x:Name="cmbTypeFace"
                              Height="42"
                              FontSize="15"
                              materialDesign:HintAssist.Hint="Выберите тип лица" SelectionChanged="Filter_SelectionChanged"
                             />

                    
                </StackPanel>
            </Border>

            <!-- Правая область с карточками -->
            <ScrollViewer Grid.Column="1" 
                          
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled" Width=" 490"
                          HorizontalAlignment="Right">
                <ItemsControl x:Name="itemsControlCounterparty" BorderBrush="#FF424242"  BorderThickness="1" Width="450" Margin="10">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Margin="10"
                                       Orientation="Horizontal"
                                       ItemWidth="430"
                                       ItemHeight="205"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>
            </ScrollViewer>
        </Grid>
    </Grid>
</Window>